	"permission": {
		"edit": "allow",
		"bash": "allow",
		"webfetch": "allow",
		"doom_loop": "allow",
		"external_directory": "allow",
		"skill": {
			"*": "allow"
		}
	},
	"mcp": {
		"sequential-thinking": {
			"enabled": true,
			"type": "local",
			"command": [
				"npx",
				"npx",
				"@modelcontextprotocol/server-sequential-thinking"
			]
		},
		"context7": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"figma-desktop": {
			"enabled": true,
			"type": "remote",
			"url": "http://127.0.0.1:3845/mcp"
		},
		"mgrep": {
			"enabled": true,
			"type": "local",
			"command": ["mgrep", "mcp"]
		}
	},
	"instructions": ["~/.config/opencode/output-styles/engineer-professional.md"],
	"plugin": ["oh-my-opencode@latest"]
}
