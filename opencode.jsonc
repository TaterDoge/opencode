{
	"$schema": "https://opencode.ai/config.json",
	"theme": "system",
	"provider": {
		"x-aio": {
			"npm": "@ai-sdk/openai-compatible",
			// "npm": "@ai-sdk/anthropic",
			"name": "x-aio",
			"options": {
				"baseURL": "https://code-api.x-aio.com/v1",
				"apiKey": "{env:CODEPLAN_API_KEY}"
			},
			"models": {
				"XAIO-C-4-5-Opus": {
					"name": "XAIO-C-4-5-Opus",
					"options": {
						"thinking": {
							"type": "enabled",
							"budgetTokens": 16000
						}
					}
				},
				"XAIO-C-4-5-Sonnet": {
					"name": "XAIO-C-4-5-Sonnet",
					"options": {
						"thinking": {
							"type": "enabled",
							"budgetTokens": 16000
						}
					}
				},
				"XAIO-O-G5-2": {
					"name": "XAIO-O-G5-2",
					"options": {
						"store": false
					}
				},
				"XAIO-O-G5-2-Codex": {
					"name": "XAIO-O-G5-2-Codex",
					"options": {
						"store": false
					}
				},
				"XAIO-G-3-Pro-Preview": {
					"name": "XAIO-G-3-Pro-Preview"
				},
				"XAIO-G-3-Flash-Preview": {
					"name": "XAIO-G-3-Flash-Preview"
				},
				"GLM-4.7": {
					"name": "GLM-4.7"
				},
				"MiniMax-M2.1": {
					"name": "MiniMax-M2.1"
				}
			}
		}
	},
	"permission": {
		"edit": "allow",
		"bash": "allow",
		"webfetch": "allow",
		"doom_loop": "allow",
		"external_directory": "allow",
		"skill": {
			"*": "allow"
		}
	},
	"mcp": {
		"playwright": {
			"enabled": true,
			"type": "local",
			"command": ["npx", "@playwright/mcp@latest"]
		},
		"context7": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"figma-desktop": {
			"enabled": true,
			"type": "remote",
			"url": "http://127.0.0.1:3845/mcp"
		},
		"mgrep": {
			"enabled": true,
			"type": "local",
			"command": ["mgrep", "mcp"]
		}
	},
	"plugin": [
		"oh-my-opencode",
		"@tarquinen/opencode-dcp@latest" // OpenCode 动态上下文修剪插件——智能管理对话上下文以优化令牌使用情况
	]
}
