{
	"$schema": "https://opencode.ai/config.json",
	"theme": "system",
	"model": "xaio/Kimi-K2.5",
	"small_model": "xaio/MiniMax-M2.1",
	"provider": {
		"x-aio": {
			"npm": "@ai-sdk/openai-compatible",
			// "npm": "@ai-sdk/anthropic",
			"name": "x-aio",
			"options": {
				// "baseURL": "https://code-api.x-aio.com/anthropic/v1",
				"baseURL": "https://code-api.x-aio.com/v1",
				"apiKey": "{env:XAIO_API_KEY}"
			},
			"models": {
				"Qwen3-30B-A3B-Instruct-2507": {
					"limit": {
						"context": 256000,
						"output": 32000
					}
				},
				"Qwen3-30B-A3B-Thinking-2507": {
					"limit": {
						"context": 128000,
						"output": 32000
					},
					"reasoning": true
				},
				"Qwen3-Coder-480B-A35B-Instruct": {
					"limit": {
						"context": 256000,
						"output": 32000
					}
				},
				"Qwen3-Coder-30B-A3B-Instruct": {
					"limit": {
						"context": 64000,
						"output": 32000
					}
				},
				"Qwen3-VL-30B-A3B-Instruct": {
					"limit": {
						"context": 64000,
						"output": 32000
					},
					"modalities": {
						"input": ["text", "image", "video"],
						"output": ["text"]
					}
				},
				"Qwen3-VL-235B-A22B-Instruct": {
					"limit": {
						"context": 256000,
						"output": 32000
					},
					"modalities": {
						"input": ["text", "image", "video"],
						"output": ["text"]
					}
				},
				"MiniMax-M2": {
					"limit": {
						"context": 192000,
						"output": 32000
					},
					"reasoning": true
				},
				"DeepSeek-V3.2": {
					"limit": {
						"context": 128000,
						"output": 32000
					}
				},
				"DeepSeek-V3.2-Thinking": {
					"limit": {
						"context": 128000,
						"output": 32000
					},
					"reasoning": true,
					"interleaved": {
						"field": "reasoning_content"
					}
				},
				"Kimi-K2-Instruct-0905": {
					"limit": {
						"context": 256000,
						"output": 32000
					}
				},
				"XAIO-G-3-Pro-Preview": {
