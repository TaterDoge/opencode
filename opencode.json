{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "provider": {
    "x-aio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "x-aio",
      "options": {
        "baseURL": "https://code-api.x-aio.com/v1",
        "apiKey": "{env:CODEPLAN_API_KEY}"
      },
      "models": {
        "XAIO-O-G5-2": {
          "name": "XAIO-O-G5-2",
          "options": {
            "store": false
          }
        },
        "XAIO-O-G5-2-Codex": {
          "name": "XAIO-O-G5-2-Codex",
          "options": {
            "store": false
          }
        },
        "XAIO-C-4-5-Opus": {
          "name": "XAIO-C-4-5-Opus"
        },
        "XAIO-C-4-5-Sonnet": {
          "name": "XAIO-C-4-5-Sonnet"
        },
        "XAIO-G-3-Flash-Preview": {
          "name": "XAIO-G-3-Flash-Preview"
        },
        "GLM-4.7": {
          "name": "GLM-4.7"
        },
      }
    },
    "x-aio-responses": {
      "npm": "@ai-sdk/openai",
      "name": "x-aio-responses",
      "options": {
        "baseURL": "https://code-api.x-aio.com/v1",
        "apiKey": "{env:CODEPLAN_API_KEY}"
      },
      "models": {
        "XAIO-O-G5-2": {
          "name": "XAIO-O-G5-2",
          "options": {
            "store": false
          }
        },
        "XAIO-O-G5-2-Codex": {
          "name": "XAIO-O-G5-2-Codex",
          "options": {
            "store": false
          }
        },
      }
    },
    "antigravity": {
      "npm": "@ai-sdk/anthropic",
      "name": "antigravity",
      "options": {
        "baseURL": "http://127.0.0.1:8045/v1",
        "apiKey": "{env:ANTIGRAVITY_API_KEY}"
      },
      "models": {
        "claude-opus-4-5-thinking": {
          "name": "claude-opus-4-5-thinking",
          "limit": {
            "context": 200000,
            "output": 64000
          },
        },
        "claude-sonnet-4-5-thinking": {
          "name": "claude-opus-4-5-thinking",
          "limit": {
            "context": 200000,
            "output": 64000
          },
        },
        "gemini-3-flash": {
          "name": "gemini-3-flash",
        },
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "doom_loop": "allow",
    "external_directory": "allow",
    "skill": {
      "*": "allow"
    }
  },
  "mcp": {
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "figma-desktop": {
      "enabled": true,
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "mgrep": {
      "enabled": true,
      "type": "local",
      "command": [
        "mgrep",
        "mcp"
      ]
    }
  },
  "plugin": [
    "oh-my-opencode"
  ]
}
